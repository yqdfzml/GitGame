{
  "name": "gitgame",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:frontend": "pnpm --filter gitgame-frontend dev",
    "dev:backend": "pnpm --filter gitgame-backend dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter gitgame-backend test",
    "db:migrate": "pnpm --filter gitgame-backend prisma:migrate",
    "db:seed": "pnpm --filter gitgame-backend prisma:seed",
    "db:generate": "pnpm --filter gitgame-backend prisma:generate"
  }
}
