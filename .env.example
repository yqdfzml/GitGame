# 复制为 .env 后填写，后端所有带 * 的项均为必填，代码内不提供默认值兜底
# cp .env.example .env

# 前端：留空表示走 Vite 同源代理；删除此行则完全关闭云同步
VITE_API_BASE_URL=

# 后端（* 必填）
APP_ENV=development
APP_PORT=3000
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=git_game
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=3600
CORS_ORIGIN=http://localhost:5173
